{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and roles",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "createdAt", "updatedAt"]
    },
    "Booking": {
      "title": "Booking Request",
      "description": "Cab booking details",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "customerEmail": { "type": "string" },
        "pickup": { "type": "string" },
        "dropoff": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "passengers": { "type": "integer" },
        "vehicle": { "type": "string" },
        "features": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] },
        "contactPreferences": {
          "type": "object",
          "properties": {
            "whatsapp": { "type": "boolean" },
            "email": { "type": "boolean" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "customerPhone", "pickup", "dropoff", "date", "passengers", "vehicle", "status", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "All booking requests"
    }
  }
}
