rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.get('email', '') == 'darajazb@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'customer') == 'admin')
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Admins Collection ---
    match /admins/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow get: if isValidId(userId) && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();
      
      function isValidUser(data) {
        return data.keys().hasAll(['email', 'name', 'role', 'createdAt', 'updatedAt']) &&
               data.keys().size() == 5 &&
               data.email is string && data.email.size() <= 200 &&
               data.name is string && data.name.size() <= 200 &&
               data.role in ['customer', 'admin'] &&
               data.createdAt == request.time &&
               data.updatedAt == request.time;
      }

      allow create: if isValidId(userId) && isOwner(userId) && isValidUser(incoming()) && incoming().role == 'customer';
      allow update: if isValidId(userId) && (isOwner(userId) || isAdmin()) && (
        (isOwner(userId) && !isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'updatedAt']) && incoming().updatedAt == request.time) ||
        (isAdmin() && incoming().updatedAt == request.time)
      );
    }

    // --- Bookings Collection ---
    match /bookings/{bookingId} {
      allow get: if (resource.data.userId == 'guest') || (isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin()));
      allow list: if (isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin()));

      function isValidBooking(data) {
        return data.keys().hasAll(['bookingId', 'userId', 'customerName', 'customerPhone', 'customerEmail', 'pickup', 'dropoff', 'date', 'passengers', 'vehicle', 'features', 'status', 'isCustom', 'contactPreferences', 'createdAt', 'updatedAt']) &&
               data.keys().size() == 16 &&
               data.bookingId is string &&
               data.userId is string && data.userId.size() <= 128 &&
               data.customerName is string && data.customerName.size() >= 1 && data.customerName.size() <= 200 &&
               data.customerPhone is string && data.customerPhone.size() >= 1 && data.customerPhone.size() <= 30 &&
               data.customerEmail is string && data.customerEmail.size() <= 200 &&
               data.pickup is string && data.pickup.size() >= 1 && data.pickup.size() <= 500 &&
               data.dropoff is string && data.dropoff.size() >= 1 && data.dropoff.size() <= 500 &&
               data.date is string && data.date.size() <= 100 &&
               (data.passengers is int || data.passengers is number || data.passengers is string) && 
               data.vehicle is string && data.vehicle.size() <= 500 &&
               data.features is list && data.features.size() <= 50 &&
               data.status in ['pending', 'confirmed', 'cancelled', 'completed'] &&
               data.isCustom is bool &&
               data.contactPreferences is map &&
               data.contactPreferences.keys().hasAll(['whatsapp', 'email']) &&
               data.contactPreferences.whatsapp is bool &&
               data.contactPreferences.email is bool &&
               data.createdAt == request.time &&
               data.updatedAt == request.time;
      }

      allow create: if (isSignedIn() && isValidBooking(incoming()) && incoming().userId == request.auth.uid && incoming().status == 'pending') ||
                    (!isSignedIn() && isValidBooking(incoming()) && incoming().userId == 'guest' && incoming().status == 'pending');

      allow update: if (isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin())) && (
        (resource.data.userId == request.auth.uid && existing().status == 'pending' && 
         incoming().diff(existing()).affectedKeys().hasOnly(['customerName', 'customerPhone', 'customerEmail', 'pickup', 'dropoff', 'date', 'passengers', 'vehicle', 'features', 'contactPreferences', 'updatedAt']) && 
         incoming().updatedAt == request.time) ||
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) && incoming().updatedAt == request.time)
      );
      
      allow delete: if isAdmin();
    }

    // --- Fleet, Drivers, Packages, Rates: Public Read, Admin Write ---
    match /fleet/{vehicleId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    match /drivers/{driverId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    match /packages/{packageId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    match /rates/{rateId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    // --- Site Settings ---
    match /settings/{settingId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    // Default Deny (Last Rule)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
